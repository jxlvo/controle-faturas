generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING") // Mantenha se a Vercel tiver criado essa também
}

// O seu model Expense aqui embaixo continua exatamente igual! Não precisa mexer.

model Expense {
  id              String   @id @default(uuid())
  purchaseDate    DateTime // Data real da compra
  title           String   // Ex: "Botequim" ou "Mercadolivre - Parcela 1/3"
  amount          Float    // Valor 
  responsible     String   // "Julinho" ou "Fabiana"
  invoiceMonth    String   // Mês da fatura (ex: "2026-07")
  isInstallment   Boolean  @default(false)
  createdAt       DateTime @default(now())
}